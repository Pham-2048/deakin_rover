# NodeControl.srv - Custom service for GUI node management
# The GUI sends JSON-encoded control data in the request.
# Used by /node_manager/launch and /node_manager/stop services.
#
# Launch request example: {"node_id": "camera_node", "package": "rover_camera", "executable": "camera_node"}
# Stop request example:   {"node_id": "camera_node"}
string data
---
bool success
string message
