<robot name="robot_arm">
 	<link name="base_link">
		<visual>
		    <origin xyz="0 0 0.025" rpy="0 0 0"/>
			<geometry>
				<cylinder length="0.050" radius="0.1"/>
			</geometry>
		</visual>
		<collision>
		    <origin xyz="0 0 0.025" rpy="0 0 0"/>
			<geometry>
				<cylinder length="0.050" radius="0.1"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="1.0"/>
			<!-- cylinder r=0.1, h=0.05: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
			<inertia ixx="0.026" ixy="0" ixz="0"
			                     iyy="0.026" iyz="0"
			                                 izz="0.005"/>
		</inertial>
	</link>

    <joint name="base_joint" type="revolute">
      <parent link="base_link"/>
      <child link="base_rot"/>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <axis xyz="0 0 -1"/>
      <limit lower="-6.28" upper="6.28" effort="10.0" velocity="1.0"/>
    </joint>

    <link name="base_rot">
		<visual>
      <origin xyz="0 0 0.035" rpy="0 0 0" />
          	<geometry>
                <box size="0.1 0.1 0.07" />
			</geometry>
		</visual>
		<collision>
      <origin xyz="0 0 0.035" rpy="0 0 0" />
          	<geometry>
                <box size="0.1 0.1 0.07" />
			</geometry>
		</collision>
		<inertial>
			<mass value="0.5"/>
			<!-- box 0.1x0.1x0.07: Ixx=m(y²+z²)/12, Iyy=m(x²+z²)/12, Izz=m(x²+y²)/12 -->
			<inertia ixx="0.000704" ixy="0" ixz="0"
			                        iyy="0.000704" iyz="0"
			                                       izz="0.000833"/>
		</inertial>
	</link>

      <joint name="shoulder_joint" type="revolute">
      <parent link="base_rot"/>
      <child link="arm1"/>
      <origin xyz="0 0 0.07" rpy="0 0 0" />
      <axis xyz="1 0 0"/>
      <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
    </joint>

    <link name="arm1">
		<visual>
          <origin xyz="0 0 0.25" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.5" radius="0.02"/>
			</geometry>
		</visual>
		<collision>
          <origin xyz="0 0 0.25" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.5" radius="0.02"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.3"/>
			<!-- cylinder r=0.02, h=0.5: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
			<inertia ixx="0.006" ixy="0" ixz="0"
			                     iyy="0.006" iyz="0"
			                                 izz="0.00006"/>
		</inertial>
	</link>

    <joint name="elbow_joint" type="revolute">
      <parent link="arm1"/>
      <child link="arm2"/>
      <origin xyz="0.08 0 0.5" rpy="0 0 0" />
      <axis xyz="1 0 0"/>
        <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0"/>
    </joint>

    <link name="arm2">
		<visual>
          <origin xyz="0 0 0.25" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.5" radius="0.02"/>
			</geometry>
		</visual>
		<collision>
          <origin xyz="0 0 0.25" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.5" radius="0.02"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.3"/>
			<!-- cylinder r=0.02, h=0.5: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
			<inertia ixx="0.006" ixy="0" ixz="0"
			                     iyy="0.006" iyz="0"
			                                 izz="0.00006"/>
		</inertial>
  </link>

    <joint name="ee_joint" type="fixed">
    <parent link="arm2"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>

  <link name="ee_link">
		<visual>
          <origin xyz="0 0 0.025" rpy="0 0 0" />
          	<geometry>
            	<box size="0.1 0.1 0.05" />
			</geometry>
		</visual>
		<collision>
          <origin xyz="0 0 0.025" rpy="0 0 0" />
          	<geometry>
            	<box size="0.1 0.1 0.05" />
			</geometry>
		</collision>
		<inertial>
			<mass value="0.2"/>
			<!-- box 0.1x0.1x0.05: Ixx=m(y²+z²)/12, Iyy=m(x²+z²)/12, Izz=m(x²+y²)/12 -->
			<inertia ixx="0.000208" ixy="0" ixz="0"
			                        iyy="0.000208" iyz="0"
			                                       izz="0.000333"/>
		</inertial>
    </link>

</robot>
