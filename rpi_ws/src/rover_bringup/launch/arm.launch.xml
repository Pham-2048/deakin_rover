<launch>
  <!-- Arm launch — motor_node (IK/FK + CAN) and socketcan_bridge (real hw only).
       In mock mode, motor_node runs without CAN hardware.

       MOCK MODE: motor_node runs with use_mock:=true; socketcan_bridge is skipped.
       HARDWARE UPGRADE: Set use_mock:=false to enable socketcan_bridge and real CAN.
  -->

  <arg name="use_mock" default="true" description="Use mock mode (skips socketcan_bridge)"/>

  <!-- socketcan_bridge — only launched on real hardware (skipped in mock mode) -->
  <node pkg="nobleo_socketcan_bridge" exec="socketcan_bridge" name="socketcan_bridge_node"
        output="screen" unless="$(var use_mock)">
    <param name="can_device" value="can0"/>
  </node>

  <!-- motor_node — IK/FK arm controller -->
  <node pkg="motor_node" exec="start_controller" name="motor_node" output="screen">
    <param name="use_mock" value="$(var use_mock)"/>
  </node>
</launch>
