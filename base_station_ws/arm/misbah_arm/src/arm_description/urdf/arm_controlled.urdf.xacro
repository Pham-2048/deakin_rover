<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_arm">

  <xacro:arg name="use_ros2_control" default="true"/>

  <!-- Arm geometry (from DCR-Arm-2026 reference design) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.050" radius="0.1"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base_rot"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit effort="50.0" velocity="1.0" lower="-6.28" upper="6.28"/>
  </joint>

  <link name="base_rot">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.07"/>
      </geometry>
    </visual>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="base_rot"/>
    <child link="arm1"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="50.0" velocity="1.0" lower="-1.57" upper="1.57"/>
  </joint>

  <link name="arm1">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.5" radius="0.02"/>
      </geometry>
    </visual>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="arm1"/>
    <child link="arm2"/>
    <origin xyz="0.08 0 0.5" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="50.0" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="arm2">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.5" radius="0.02"/>
      </geometry>
    </visual>
  </link>

  <joint name="ee_joint" type="fixed">
    <parent link="arm2"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>

  <link name="ee_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- ros2_control hardware interface block (disabled for visualization-only launches) -->
  <xacro:if value="$(arg use_ros2_control)">
    <ros2_control name="ArmSystem" type="system">

      <!-- In simulation: use mock hardware (no real motors needed) -->
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
      </hardware>

      <joint name="base_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <joint name="shoulder_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

      <joint name="elbow_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>

    </ros2_control>
  </xacro:if>

</robot>
